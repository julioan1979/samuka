# Airtable Configuration
AIRTABLE_API_KEY=your_airtable_api_key_here

# Global Base (tenants, users, payment methods, suppliers)
AIRTABLE_GLOBAL_BASE_ID=appXXXXXXXXXXXXXX

# Tenant Operational Bases (one base ID per tenant)
# Format: AIRTABLE_BASE_<TENANT_SLUG>=appXXXXXXXXXXXXXX
AIRTABLE_BASE_CASA_DA_PIZZA=appXXXXXXXXXXXXXX
AIRTABLE_BASE_JULIPAN=appXXXXXXXXXXXXXX

# App Settings
APP_TITLE=CashCheck
APP_ENV=development
